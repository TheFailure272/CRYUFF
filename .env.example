# ──────────────────────────────────────────────────────────────
# C.R.U.Y.F.F. — Environment Configuration
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and adjust values for your environment.
# All variables are prefixed with CRUYFF_ (Pydantic Settings).
# ──────────────────────────────────────────────────────────────

# ── Redis ────────────────────────────────────────────────────
CRUYFF_REDIS_URL=redis://localhost:6379/0
CRUYFF_REDIS_CHANNEL_RAW=cruyff:tracking:raw
CRUYFF_REDIS_CHANNEL_RESULT=cruyff:analysis:result

# ── WebSocket Gateway ────────────────────────────────────────
CRUYFF_WS_TICK_HZ=25
CRUYFF_WS_HOST=0.0.0.0
CRUYFF_WS_PORT=8000

# ── Topological Solver (Layer 1: The Flow) ───────────────────
CRUYFF_TOPO_MAX_EDGE_LENGTH=0.35
CRUYFF_TOPO_MAX_DIMENSION=2
CRUYFF_TOPO_PERSISTENCE_THRESHOLD=0.04
CRUYFF_TOPO_USE_DEFENSIVE_ONLY=true
CRUYFF_TOPO_DYNAMIC_TEAM_ID=true
CRUYFF_TOPO_VELOCITY_HORIZON_SECS=0.5

# ── Temporal Smoothing (Kalman Filter) ───────────────────────
CRUYFF_TOPO_EMA_ALPHA=0.3
CRUYFF_TOPO_STABILITY_THRESHOLD=0.6
CRUYFF_TOPO_MATCH_RADIUS=0.05

# ── BioKinetic Engine (Layer 2: The Pulse) ───────────────────
CRUYFF_BIO_SCAN_WINDOW_SECS=5.0
CRUYFF_BIO_MICRO_VAR_THRESHOLD=0.015
CRUYFF_BIO_COGNITIVE_COLLAPSE_THRESHOLD=0.6

# ── Ghost Trajectory Engine (Layer 3: The Ghost) ─────────────
CRUYFF_GHOST_DIFFUSION_STEPS=20
# CRUYFF_GHOST_XT_GRID_RESOLUTION=(104, 68)

# ── Worker ───────────────────────────────────────────────────
CRUYFF_WORKER_THREAD_POOL_SIZE=4
CRUYFF_WORKER_STALE_FRAME_MS=100.0

# ── Docker / Production ─────────────────────────────────────
# REDIS_URL=redis://redis:6379/0      (overrides CRUYFF_REDIS_URL in Docker)
# LOG_LEVEL=info
